{
    "extends": "@crudstack/typescript-config/base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDirs": ["./src", "./tests"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
